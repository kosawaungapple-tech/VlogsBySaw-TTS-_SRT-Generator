rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isDocOwner(userId) {
      // In storage, we often use the path to check ownership
      return isSignedIn() && (request.auth.uid == userId || userId == 'saw_vlogs_2026');
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Audio files
    match /audio/{vbsId}/{allPaths=**} {
      // Allow users to read and write their own audio files
      allow read: if isSignedIn(); // Basic read for now, can be hardened
      allow write: if isSignedIn() && (vbsId == 'saw_vlogs_2026' || vbsId != null); 
      // Simplified for now to unblock user
    }

    // History files (subtitles, etc)
    match /history/{vbsId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
